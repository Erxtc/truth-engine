{
  "name": "truth-engine",
  "private": true,
  "scripts": {
    "develop":    "bash scripts/develop.sh",
    "start":      "bun run src/main.ts",
    "typecheck":  "tsc --noEmit",
    "test":       "bun run src/test/benchmark.ts",
    "test:quick": "bun run src/test/benchmark.ts --quick",
    "ui:build":   "vite build src/ui/frontend",
    "ui:dev":     "vite src/ui/frontend",
    "db:generate":"drizzle-kit generate && bun run src/db/gen-types.ts",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "jsonrepair": "^3.14.0",
    "kysely": "^0.29.2",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "svelte": "^4",
    "vite": "^5"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
