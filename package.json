    "better-sqlite3": "^12.10.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "jsonrepair": "^3.14.0",
    "kysely": "^0.29.2",
    "simple-git": "^3.36.0",
    "ts-node": "^10.9.2",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3",
    "@types/bun": "latest",
    "svelte": "^4",
